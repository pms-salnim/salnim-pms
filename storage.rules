rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // This rule allows any authenticated user to write to the conversations path.
    // This is necessary for uploading attachments. Reading can be locked down further if needed.
    match /conversations/{conversationId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Allow public read for property logos and room type images for booking pages,
    // but only allow authenticated users to write (upload).
    match /properties/{propertyId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    match /roomTypes/{roomTypeId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    // Allow authenticated users to upload and read service images
    match /services/{propertyId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    // Allow authenticated users to upload and read meal plan images
    match /mealPlans/{propertyId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    // Allow authenticated users to upload and read guest profile images
    match /guest-profiles/{propertyId}/{reservationId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Allow authenticated users to upload and read email template images
    match /email-templates/{propertyId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    // Allow authenticated users to upload and read guest portal branding images (logos, favicons, hero images)
    match /guest-portal-logos/{portalId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    match /guest-portal-favicons/{portalId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }

    match /guest-portal-hero/{portalId}/{allPaths=**} {
      allow read;
      allow write: if request.auth != null;
    }
  }
}
