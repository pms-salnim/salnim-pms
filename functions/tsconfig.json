{
  "compilerOptions": {
    "module": "NodeNext",
    "esModuleInterop": true,
    "moduleResolution": "nodenext",
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "outDir": "lib",
    "sourceMap": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2017",
    "baseUrl": ".",
    "paths": {
      "@functions/*": [
        "source/*"
      ],
      "@shared/*": [
        "source/types/*"
      ]

    }
  },
  "compileOnSave": true,
  "include": [
    "source"
  ]
}
